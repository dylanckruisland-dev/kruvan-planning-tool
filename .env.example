# From `npx convex dev` after logging in — paste the deployment URL here.
# Production URL is also in netlify.toml (Convex prod deployment). Override in
# Netlify UI if you create a new Convex deployment.
VITE_CONVEX_URL=

# Netlify CI alternative: omit VITE_CONVEX_URL here and set only
# CONVEX_DEPLOY_KEY (Convex Dashboard → Settings → Deploy keys), then use:
#   npx convex deploy --cmd "npm run build" --cmd-url-env-var-name VITE_CONVEX_URL
# as the build command instead of npm run build.

# Convex Auth — set on each Convex deployment (Dashboard → Settings → Environment Variables),
# not in Vite. Required for production (`npx convex deploy`):
#   JWT_PRIVATE_KEY, JWKS  (from `npx @convex-dev/auth`, or copy from dev: `npx convex env list`)
#   SITE_URL               public URL of the web app (https://….netlify.app for production)
#   GEMINI_API_KEY         optional; for AI features
# CONVEX_SITE_URL is set automatically by Convex Cloud and cannot be overridden.

# Gemini for Generate content: set on the Convex deployment, not here (never VITE_*).
# npx convex env set GEMINI_API_KEY '...'   or Dashboard → Environment Variables
# Key: https://aistudio.google.com/apikey
